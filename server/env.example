# Trust Oracle Server Configuration

# --- Server ---
PORT=3000

# --- x402 Payment Protocol ---
# Get these from https://portal.cdp.coinbase.com/ -> API Keys -> Create API Key
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Your EVM wallet address on Base mainnet to receive USDC payments
PAY_TO=0xYourWalletAddress

# --- Admin ---
# Set this to protect POST /api/endpoints from unauthorized use
# Generate with: openssl rand -hex 16
ADMIN_TOKEN=

# --- XMTP Agent (run separately from xmtp-agent/) ---
# Generate a new EVM private key for the XMTP bot identity
# XMTP_WALLET_KEY=0x...
# XMTP_DB_ENCRYPTION_KEY=  # 64 hex chars, generate with: openssl rand -hex 32
# TRUST_ORACLE_URL=http://localhost:3000
